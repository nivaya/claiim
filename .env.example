# CLAIIM -- Evaluation Preview
# Copy this file to .env and fill in the required values before starting.

# Required: secret used to sign agent tokens and session JWTs.
# Generate with: openssl rand -hex 32
TOKEN_SECRET=

# Optional: deployment tier. Leave as "community" for the Evaluation Preview.
# TIER=community

# Optional: log level. Default: info. Options: debug, info, warn, error.
# LOG_LEVEL=info

# Optional: number of Chron queue workers. Default: 4.
# CHRON_QUEUE_WORKERS=4

# Production database (optional for evaluation -- bundled Postgres is used by default).
# Set this to your own PostgreSQL instance before going into production.
# DATABASE_URL=postgres://user:password@host:5432/claiim?sslmode=require
